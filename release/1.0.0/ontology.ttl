@prefix pkmn:    <https://w3id.org/doisr/pokemon#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix vann:    <http://purl.org/vocab/vann/> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@base <https://w3id.org/doisr/pokemon> .

#    Ontology metadata 

<https://w3id.org/doisr/pokemon> a owl:Ontology ;
    dcterms:title "Pokemon Ontology"@en ;
    dcterms:description "An OWL ontology describing the Pokemon domain: creatures, their types and base stats, moves and move categories, abilities, evolutions, generations and regions."@en ;
    dcterms:creator "Miguel Lopez Ferreiro" ;
    dcterms:created "2026-06-09"^^xsd:date ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    owl:versionInfo "1.0.0" ;
    owl:versionIRI <https://w3id.org/doisr/pokemon/1.0.0> ;
    vann:preferredNamespacePrefix "pkmn" ;
    vann:preferredNamespaceUri "https://w3id.org/doisr/pokemon#" ;
    dcterms:publisher "Universidad Politecnica de Madrid" ;
    dcterms:issued "2026-06-09"^^xsd:date ;
    dcterms:bibliographicCitation "Lopez Ferreiro, M. (2026). Pokemon Ontology. https://w3id.org/doisr/pokemon" ;
    dcterms:source <https://pokeapi.co/> ;
    dcterms:modified "2026-06-09"^^xsd:date ;
    prov:wasDerivedFrom <https://pokeapi.co/> .

#    Controlled vocabularies (SKOS - soft reuse)

skos:Concept a owl:Class .
skos:ConceptScheme a owl:Class .

pkmn:PokemonType a owl:Class ;
    rdfs:subClassOf skos:Concept ;
    rdfs:label "Pokemon Type"@en ;
    rdfs:comment "An elemental type of a Pokemon or a move (e.g. Fire, Water)."@en .

pkmn:MoveCategory a owl:Class ;
    rdfs:subClassOf skos:Concept ;
    rdfs:label "Move Category"@en ;
    rdfs:comment "The damage category of a move: Physical, Special or Status."@en .

pkmn:PokemonTypeScheme a skos:ConceptScheme ;
    rdfs:label "Pokemon Type Scheme"@en ;
    skos:prefLabel "Pokemon types"@en .

pkmn:MoveCategoryScheme a skos:ConceptScheme ;
    rdfs:label "Move Category Scheme"@en ;
    skos:prefLabel "Move categories"@en .

# --- The 18 official types as SKOS concepts ---
pkmn:Normal   a pkmn:PokemonType ; skos:inScheme pkmn:PokemonTypeScheme ; skos:prefLabel "Normal"@en .
pkmn:Fire     a pkmn:PokemonType ; skos:inScheme pkmn:PokemonTypeScheme ; skos:prefLabel "Fire"@en .
pkmn:Water    a pkmn:PokemonType ; skos:inScheme pkmn:PokemonTypeScheme ; skos:prefLabel "Water"@en .
pkmn:Electric a pkmn:PokemonType ; skos:inScheme pkmn:PokemonTypeScheme ; skos:prefLabel "Electric"@en .
pkmn:Grass    a pkmn:PokemonType ; skos:inScheme pkmn:PokemonTypeScheme ; skos:prefLabel "Grass"@en .
pkmn:Ice      a pkmn:PokemonType ; skos:inScheme pkmn:PokemonTypeScheme ; skos:prefLabel "Ice"@en .
pkmn:Fighting a pkmn:PokemonType ; skos:inScheme pkmn:PokemonTypeScheme ; skos:prefLabel "Fighting"@en .
pkmn:Poison   a pkmn:PokemonType ; skos:inScheme pkmn:PokemonTypeScheme ; skos:prefLabel "Poison"@en .
pkmn:Ground   a pkmn:PokemonType ; skos:inScheme pkmn:PokemonTypeScheme ; skos:prefLabel "Ground"@en .
pkmn:Flying   a pkmn:PokemonType ; skos:inScheme pkmn:PokemonTypeScheme ; skos:prefLabel "Flying"@en .
pkmn:Psychic  a pkmn:PokemonType ; skos:inScheme pkmn:PokemonTypeScheme ; skos:prefLabel "Psychic"@en .
pkmn:Bug      a pkmn:PokemonType ; skos:inScheme pkmn:PokemonTypeScheme ; skos:prefLabel "Bug"@en .
pkmn:Rock     a pkmn:PokemonType ; skos:inScheme pkmn:PokemonTypeScheme ; skos:prefLabel "Rock"@en .
pkmn:Ghost    a pkmn:PokemonType ; skos:inScheme pkmn:PokemonTypeScheme ; skos:prefLabel "Ghost"@en .
pkmn:Dragon   a pkmn:PokemonType ; skos:inScheme pkmn:PokemonTypeScheme ; skos:prefLabel "Dragon"@en .
pkmn:Dark     a pkmn:PokemonType ; skos:inScheme pkmn:PokemonTypeScheme ; skos:prefLabel "Dark"@en .
pkmn:Steel    a pkmn:PokemonType ; skos:inScheme pkmn:PokemonTypeScheme ; skos:prefLabel "Steel"@en .
pkmn:Fairy    a pkmn:PokemonType ; skos:inScheme pkmn:PokemonTypeScheme ; skos:prefLabel "Fairy"@en .

# --- The 3 move categories as SKOS concepts ---
pkmn:Physical a pkmn:MoveCategory ; skos:inScheme pkmn:MoveCategoryScheme ; skos:prefLabel "Physical"@en .
pkmn:Special  a pkmn:MoveCategory ; skos:inScheme pkmn:MoveCategoryScheme ; skos:prefLabel "Special"@en .
pkmn:Status   a pkmn:MoveCategory ; skos:inScheme pkmn:MoveCategoryScheme ; skos:prefLabel "Status"@en .

#    Classes

pkmn:Pokemon a owl:Class ;
    rdfs:label "Pokemon"@en ;
    rdfs:comment "A Pokemon species characterised by its types, base stats, abilities and evolutions."@en ;
    rdfs:subClassOf [ a owl:Restriction ; owl:onProperty pkmn:hasPrimaryType ; owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass pkmn:PokemonType ] ;
    rdfs:subClassOf [ a owl:Restriction ; owl:onProperty pkmn:hasSecondaryType ; owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass pkmn:PokemonType ] .

pkmn:LegendaryPokemon a owl:Class ;
    rdfs:subClassOf pkmn:Pokemon ;
    rdfs:label "Legendary Pokemon"@en ;
    rdfs:comment "A Pokemon flagged as legendary."@en ;
    owl:equivalentClass [ a owl:Class ; owl:intersectionOf (
        pkmn:Pokemon
        [ a owl:Restriction ; owl:onProperty pkmn:isLegendary ; owl:hasValue true ] ) ] .

pkmn:Move a owl:Class ;
    rdfs:label "Move"@en ;
    rdfs:comment "A move (attack or action) that a Pokemon can learn and use."@en ;
    rdfs:subClassOf [ a owl:Restriction ; owl:onProperty pkmn:moveHasCategory ; owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass pkmn:MoveCategory ] ;
    rdfs:subClassOf [ a owl:Restriction ; owl:onProperty pkmn:moveHasType ; owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass pkmn:PokemonType ] .

pkmn:Ability a owl:Class ;
    rdfs:label "Ability"@en ;
    rdfs:comment "A passive ability that a Pokemon may have."@en .

pkmn:Generation a owl:Class ;
    rdfs:label "Generation"@en ;
    rdfs:comment "A generation of the Pokemon franchise in which species and moves are introduced."@en .

pkmn:Region a owl:Class ;
    rdfs:label "Region"@en ;
    rdfs:comment "A geographic region of the Pokemon world associated with a generation."@en .

pkmn:Game a owl:Class ;
    rdfs:label "Game"@en ;
    rdfs:comment "A video game of the Pokemon franchise in which a Pokemon appears."@en .

pkmn:Trainer a owl:Class ;
    rdfs:label "Trainer"@en ;
    rdfs:comment "A person who catches and owns Pokemon."@en .

pkmn:Evolution a owl:Class ;
    rdfs:label "Evolution"@en ;
    rdfs:comment "Reified n-ary relation describing an evolution of a Pokemon, including its condition (e.g. level)."@en .

#    Object properties

pkmn:hasType a owl:ObjectProperty ;
    rdfs:label "has type"@en ;
    rdfs:comment "Relates a Pokemon to any of its types (primary or secondary)."@en ;
    rdfs:domain pkmn:Pokemon ;
    rdfs:range pkmn:PokemonType .

pkmn:hasPrimaryType a owl:ObjectProperty ;
    rdfs:subPropertyOf pkmn:hasType ;
    rdfs:label "has primary type"@en ;
    rdfs:comment "Relates a Pokemon to its primary type."@en ;
    rdfs:domain pkmn:Pokemon ;
    rdfs:range pkmn:PokemonType .

pkmn:hasSecondaryType a owl:ObjectProperty ;
    rdfs:subPropertyOf pkmn:hasType ;
    rdfs:label "has secondary type"@en ;
    rdfs:comment "Relates a Pokemon to its optional secondary type."@en ;
    rdfs:domain pkmn:Pokemon ;
    rdfs:range pkmn:PokemonType .

pkmn:learnsMove a owl:ObjectProperty ;
    rdfs:label "learns move"@en ;
    rdfs:comment "Relates a Pokemon to a move it can learn."@en ;
    rdfs:domain pkmn:Pokemon ;
    rdfs:range pkmn:Move .

pkmn:hasAbility a owl:ObjectProperty ;
    rdfs:label "has ability"@en ;
    rdfs:comment "Relates a Pokemon to one of its abilities."@en ;
    rdfs:domain pkmn:Pokemon ;
    rdfs:range pkmn:Ability .

pkmn:introducedInGeneration a owl:ObjectProperty ;
    rdfs:label "introduced in generation"@en ;
    rdfs:comment "Relates a Pokemon or a move to the generation in which it was introduced."@en ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( pkmn:Pokemon pkmn:Move ) ] ;
    rdfs:range pkmn:Generation .

pkmn:appearsInGame a owl:ObjectProperty ;
    rdfs:label "appears in game"@en ;
    rdfs:comment "Relates a Pokemon to a game in which it appears."@en ;
    rdfs:domain pkmn:Pokemon ;
    rdfs:range pkmn:Game .

pkmn:evolvesInto a owl:ObjectProperty ;
    rdfs:label "evolves into"@en ;
    rdfs:comment "Relates a Pokemon to the Pokemon it evolves into."@en ;
    rdfs:domain pkmn:Pokemon ;
    rdfs:range pkmn:Pokemon ;
    owl:inverseOf pkmn:evolvesFrom .

pkmn:evolvesFrom a owl:ObjectProperty ;
    rdfs:label "evolves from"@en ;
    rdfs:comment "Relates a Pokemon to the Pokemon it evolves from (inverse of evolves into)."@en ;
    rdfs:domain pkmn:Pokemon ;
    rdfs:range pkmn:Pokemon .

pkmn:hasEvolution a owl:ObjectProperty ;
    rdfs:label "has evolution"@en ;
    rdfs:comment "Relates a Pokemon to a reified evolution describing its condition."@en ;
    rdfs:domain pkmn:Pokemon ;
    rdfs:range pkmn:Evolution .

pkmn:evolutionResultsIn a owl:ObjectProperty ;
    rdfs:label "evolution results in"@en ;
    rdfs:comment "Relates a reified evolution to the resulting Pokemon."@en ;
    rdfs:domain pkmn:Evolution ;
    rdfs:range pkmn:Pokemon .

pkmn:moveHasType a owl:ObjectProperty ;
    rdfs:label "move has type"@en ;
    rdfs:comment "Relates a move to its elemental type."@en ;
    rdfs:domain pkmn:Move ;
    rdfs:range pkmn:PokemonType .

pkmn:moveHasCategory a owl:ObjectProperty ;
    rdfs:label "move has category"@en ;
    rdfs:comment "Relates a move to its damage category."@en ;
    rdfs:domain pkmn:Move ;
    rdfs:range pkmn:MoveCategory .

pkmn:generationHasRegion a owl:ObjectProperty ;
    rdfs:label "generation has region"@en ;
    rdfs:comment "Relates a generation to its associated region."@en ;
    rdfs:domain pkmn:Generation ;
    rdfs:range pkmn:Region .

pkmn:ownsPokemon a owl:ObjectProperty ;
    rdfs:label "owns pokemon"@en ;
    rdfs:comment "Relates a trainer to a Pokemon they own."@en ;
    rdfs:domain pkmn:Trainer ;
    rdfs:range pkmn:Pokemon .

#    Datatype properties

pkmn:pokedexNumber a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "pokedex number"@en ;
    rdfs:comment "The National Pokedex number of a Pokemon."@en ;
    rdfs:domain pkmn:Pokemon ; rdfs:range xsd:integer .

pkmn:hp a owl:DatatypeProperty ;
    rdfs:label "hp"@en ; rdfs:comment "Base HP stat."@en ;
    rdfs:domain pkmn:Pokemon ; rdfs:range xsd:integer .

pkmn:attack a owl:DatatypeProperty ;
    rdfs:label "attack"@en ; rdfs:comment "Base Attack stat."@en ;
    rdfs:domain pkmn:Pokemon ; rdfs:range xsd:integer .

pkmn:defense a owl:DatatypeProperty ;
    rdfs:label "defense"@en ; rdfs:comment "Base Defense stat."@en ;
    rdfs:domain pkmn:Pokemon ; rdfs:range xsd:integer .

pkmn:specialAttack a owl:DatatypeProperty ;
    rdfs:label "special attack"@en ; rdfs:comment "Base Special Attack stat."@en ;
    rdfs:domain pkmn:Pokemon ; rdfs:range xsd:integer .

pkmn:specialDefense a owl:DatatypeProperty ;
    rdfs:label "special defense"@en ; rdfs:comment "Base Special Defense stat."@en ;
    rdfs:domain pkmn:Pokemon ; rdfs:range xsd:integer .

pkmn:speed a owl:DatatypeProperty ;
    rdfs:label "speed"@en ; rdfs:comment "Base Speed stat."@en ;
    rdfs:domain pkmn:Pokemon ; rdfs:range xsd:integer .

pkmn:baseStatTotal a owl:DatatypeProperty ;
    rdfs:label "base stat total"@en ; rdfs:comment "Sum of the six base stats."@en ;
    rdfs:domain pkmn:Pokemon ; rdfs:range xsd:integer .

pkmn:heightM a owl:DatatypeProperty ;
    rdfs:label "height (m)"@en ; rdfs:comment "Height of a Pokemon in metres."@en ;
    rdfs:domain pkmn:Pokemon ; rdfs:range xsd:decimal .

pkmn:weightKg a owl:DatatypeProperty ;
    rdfs:label "weight (kg)"@en ; rdfs:comment "Weight of a Pokemon in kilograms."@en ;
    rdfs:domain pkmn:Pokemon ; rdfs:range xsd:decimal .

pkmn:classification a owl:DatatypeProperty ;
    rdfs:label "classification"@en ; rdfs:comment "Species classification (e.g. 'Seed Pokemon')."@en ;
    rdfs:domain pkmn:Pokemon ; rdfs:range xsd:string .

pkmn:isLegendary a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "is legendary"@en ; rdfs:comment "Whether the Pokemon is legendary."@en ;
    rdfs:domain pkmn:Pokemon ; rdfs:range xsd:boolean .

pkmn:power a owl:DatatypeProperty ;
    rdfs:label "power"@en ; rdfs:comment "Base power of a move (absent for status moves)."@en ;
    rdfs:domain pkmn:Move ; rdfs:range xsd:integer .

pkmn:accuracy a owl:DatatypeProperty ;
    rdfs:label "accuracy"@en ; rdfs:comment "Accuracy of a move, from 0 to 100."@en ;
    rdfs:domain pkmn:Move ; rdfs:range xsd:integer .

pkmn:powerPoints a owl:DatatypeProperty ;
    rdfs:label "power points"@en ; rdfs:comment "Number of times a move can be used (PP)."@en ;
    rdfs:domain pkmn:Move ; rdfs:range xsd:integer .

pkmn:abilityDescription a owl:DatatypeProperty ;
    rdfs:label "ability description"@en ; rdfs:comment "Textual effect of an ability."@en ;
    rdfs:domain pkmn:Ability ; rdfs:range xsd:string .

pkmn:generationNumber a owl:DatatypeProperty ;
    rdfs:label "generation number"@en ; rdfs:comment "Ordinal number of the generation."@en ;
    rdfs:domain pkmn:Generation ; rdfs:range xsd:integer .

pkmn:evolutionLevel a owl:DatatypeProperty ;
    rdfs:label "evolution level"@en ; rdfs:comment "Level at which the evolution occurs (if level-based)."@en ;
    rdfs:domain pkmn:Evolution ; rdfs:range xsd:integer .

pkmn:evolutionCondition a owl:DatatypeProperty ;
    rdfs:label "evolution condition"@en ; rdfs:comment "Non-level condition that triggers the evolution (e.g. an evolution stone)."@en ;
    rdfs:domain pkmn:Evolution ; rdfs:range xsd:string .

#    Improvements after OOPS! evaluation (task 2g)

# --- P10 (Important): declare disjointness among top-level classes ---
[] a owl:AllDisjointClasses ;
   owl:members ( pkmn:Pokemon pkmn:Move pkmn:Ability pkmn:Generation
                 pkmn:Region pkmn:Game pkmn:Trainer pkmn:Evolution
                 pkmn:PokemonType pkmn:MoveCategory ) .

# --- P13 (Minor): inverse properties for the main navigational relations ---
pkmn:isLearnedBy a owl:ObjectProperty ;
    rdfs:label "is learned by"@en ;
    rdfs:comment "Relates a move to the Pokemon that can learn it (inverse of learns move)."@en ;
    rdfs:domain pkmn:Move ; rdfs:range pkmn:Pokemon ;
    owl:inverseOf pkmn:learnsMove .

pkmn:isAbilityOf a owl:ObjectProperty ;
    rdfs:label "is ability of"@en ;
    rdfs:comment "Relates an ability to the Pokemon that has it (inverse of has ability)."@en ;
    rdfs:domain pkmn:Ability ; rdfs:range pkmn:Pokemon ;
    owl:inverseOf pkmn:hasAbility .

pkmn:isTypeOfMove a owl:ObjectProperty ;
    rdfs:label "is type of move"@en ;
    rdfs:comment "Relates a type to the moves of that type (inverse of move has type)."@en ;
    rdfs:domain pkmn:PokemonType ; rdfs:range pkmn:Move ;
    owl:inverseOf pkmn:moveHasType .

pkmn:isOwnedByTrainer a owl:ObjectProperty ;
    rdfs:label "is owned by trainer"@en ;
    rdfs:comment "Relates a Pokemon to its trainer (inverse of owns pokemon)."@en ;
    rdfs:domain pkmn:Pokemon ; rdfs:range pkmn:Trainer ;
    owl:inverseOf pkmn:ownsPokemon .

# --- P08 (Minor): rdfs:label on the ontology and SKOS resources ---
<https://w3id.org/doisr/pokemon> rdfs:label "Pokemon Ontology"@en .
pkmn:PokemonTypeScheme rdfs:label "Pokemon Type Scheme"@en .
pkmn:MoveCategoryScheme rdfs:label "Move Category Scheme"@en .
pkmn:Normal rdfs:label "Normal"@en . pkmn:Fire rdfs:label "Fire"@en .
pkmn:Water rdfs:label "Water"@en . pkmn:Electric rdfs:label "Electric"@en .
pkmn:Grass rdfs:label "Grass"@en . pkmn:Ice rdfs:label "Ice"@en .
pkmn:Fighting rdfs:label "Fighting"@en . pkmn:Poison rdfs:label "Poison"@en .
pkmn:Ground rdfs:label "Ground"@en . pkmn:Flying rdfs:label "Flying"@en .
pkmn:Psychic rdfs:label "Psychic"@en . pkmn:Bug rdfs:label "Bug"@en .
pkmn:Rock rdfs:label "Rock"@en . pkmn:Ghost rdfs:label "Ghost"@en .
pkmn:Dragon rdfs:label "Dragon"@en . pkmn:Dark rdfs:label "Dark"@en .
pkmn:Steel rdfs:label "Steel"@en . pkmn:Fairy rdfs:label "Fairy"@en .
pkmn:Physical rdfs:label "Physical"@en . pkmn:Special rdfs:label "Special"@en .
pkmn:Status rdfs:label "Status"@en .
